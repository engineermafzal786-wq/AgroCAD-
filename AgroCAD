      const interval = parseFloat(document.getElementById('i-mad').value) ? 
        (parseFloat(document.getElementById('i-fc').value) - parseFloat(document.getElementById('i-pwp').value)) * 
        parseFloat(document.getElementById('i-root').value) * 10 * (parseFloat(document.getElementById('i-mad').value) / 100) / eto / kc 
