      const projectLife = parseFloat(document.getElementById('fe-project-life').value);
      const discountRate = parseFloat(document.getElementById('fe-discount-rate').value) / 100;
      const residualValue = parseFloat(document.getElementById('fe-residual').value) / 100;

      if (!area || !yield_ || !price || !beArea) return;

      // === REVENUE & MARGINS ===
      const totalYield = area * yield_;
