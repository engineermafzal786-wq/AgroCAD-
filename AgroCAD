    function esc(s) { const d = document.createElement('div'); d.textContent = s || ''; return d.innerHTML; }

    // === CALCULATORS ===

    function calcET0() {
      const tMax = parseFloat(document.getElementById('w-temp-max').value);
      const tMin = parseFloat(document.getElementById('w-temp-min').value);
      const rh = parseFloat(document.getElementById('w-humidity').value);
      const u2 = parseFloat(document.getElementById('w-wind').value);
      const Rs = parseFloat(document.getElementById('w-radiation').value);
      const alt = parseFloat(document.getElementById('w-altitude').value);
      if (isNaN(tMax) || isNaN(tMin) || isNaN(u2) || isNaN(Rs)) return;

      const Tavg = (tMax + tMin) / 2;
      const P = 101.3 * Math.pow((293 - 0.0065 * alt) / 293, 5.26);
      const gamma = 0.000665 * P;

      const esat_max = 0.6108 * Math.exp((17.27 * tMax) / (tMax + 237.3));
      const esat_min = 0.6108 * Math.exp((17.27 * tMin) / (tMin + 237.3));
      const es = (esat_max + esat_min) / 2;
      const ea = (rh / 100) * es;

      const delta = (4098 * 0.6108 * Math.exp((17.27 * Tavg) / (Tavg + 237.3))) / Math.pow(Tavg + 237.3, 2);

      const Rso = (0.75 + 2e-5 * alt) * 37.6;
      const Rns = 0.77 * Rs;
      const sigma = 4.903e-9;
      const Rnl = sigma * ((Math.pow(tMax + 273.16, 4) + Math.pow(tMin + 273.16, 4)) / 2) * (0.34 - 0.14 * Math.sqrt(ea)) * (1.35 * (Rs / Rso) - 0.35);
      const Rn = Rns - Rnl;
      const G = 0;

      const cn = 900;
      const cd = 0.34;
      const num = 0.408 * delta * (Rn - G) + gamma * (cn / (Tavg + 273)) * u2 * (es - ea);
      const den = delta + gamma * (1 + cd * u2);
      const ET0 = Math.max(0.1, num / den);

      const el = document.getElementById('et0-result');
      el.classList.remove('hidden');
      el.innerHTML = `<p class="font-bold text-blue-800 mb-2">FAO-56 Penman-Monteith Results:</p><p class="text-sm"><strong>ET₀ = ${ET0.toFixed(2)} mm/day</strong></p>`;
      document.getElementById('w-eto-input').value = ET0.toFixed(2);
    }

    function calcWater() {
      const area = parseFloat(document.getElementById('w-area').value);
      const eto = parseFloat(document.getElementById('w-eto-input').value);
      const kc = parseFloat(document.getElementById('w-kc').value);
      const eff = parseFloat(document.getElementById('w-eff').value) / 100;
      const rain = parseFloat(document.getElementById('w-rain').value) || 0;
      const days = parseFloat(document.getElementById('w-days').value);
      if (!area || !eto || !kc || !eff || !days) return;

      const areaM2 = area * 4046.86;
      const ETc_daily = eto * kc;
      const netDaily = Math.max(0, ETc_daily - rain);
      const grossDaily = netDaily / eff;
      const volDaily_m3 = (grossDaily / 1000) * areaM2;
      const grossWeekly = netDaily * 7 / eff;
      const volWeekly_m3 = (grossWeekly / 1000) * areaM2;
      const grossSeason = netDaily * days / eff;
      const volSeason_m3 = (grossSeason / 1000) * areaM2;

      const el = document.getElementById('water-result');
      el.classList.remove('hidden');
      el.innerHTML = `
        <div class="space-y-3">
          <p class="font-bold text-green-800">Daily:</p>
          <p class="text-sm">ETc: <strong>${ETc_daily.toFixed(2)} mm/day</strong> | Net: <strong>${netDaily.toFixed(2)} mm</strong> | Gross: <strong>${grossDaily.toFixed(2)} mm</strong> | Volume: <strong>${volDaily_m3.toFixed(1)} m³</strong></p>
          <p class="font-bold text-green-800">Weekly:</p>
          <p class="text-sm">Gross: <strong>${grossWeekly.toFixed(2)} mm</strong> | Volume: <strong>${volWeekly_m3.toFixed(1)} m³</strong></p>
          <p class="font-bold text-green-800">Seasonal (${days} days):</p>
          <p class="text-sm">Gross: <strong>${grossSeason.toFixed(1)} mm</strong> | Volume: <strong>${volSeason_m3.toFixed(0)} m³</strong></p>
        </div>`;
    }

    function calcIrrigation() {
      const root = parseFloat(document.getElementById('i-root').value);
      const fc = parseFloat(document.getElementById('i-fc').value) / 100;
      const pwp = parseFloat(document.getElementById('i-pwp').value) / 100;
      const mad = parseFloat(document.getElementById('i-mad').value) / 100;
      const etc = parseFloat(document.getElementById('i-eto').value);
      if (!root || !fc || !pwp || !mad || !etc) return;
      const taw = (fc - pwp) * root * 10;
      const raw = taw * mad;
      const interval = raw / etc;
      const el = document.getElementById('irr-result');
      el.classList.remove('hidden');
      el.innerHTML = `<p class="font-bold text-green-800">Results:</p><p class="text-sm">TAW: <strong>${taw.toFixed(1)} mm</strong></p><p class="text-sm">RAW: <strong>${raw.toFixed(1)} mm</strong></p><p class="text-sm">Irrigation Interval: <strong>${interval.toFixed(1)} days</strong></p><p class="text-sm">Net Application Depth: <strong>${raw.toFixed(1)} mm</strong></p>`;
    }

    function calcLeveling() {
      const l = parseFloat(document.getElementById('l-length').value);
      const w = parseFloat(document.getElementById('l-width').value);
      const high = parseFloat(document.getElementById('l-high').value);
      const low = parseFloat(document.getElementById('l-low').value);
      const avg = parseFloat(document.getElementById('l-avg').value);
      if (!l || !w) return;
      const area = l * w;
      const cutVol = ((high - avg) / 2) * area;
      const fillVol = ((avg - low) / 2) * area;
      const el = document.getElementById('level-result');
      el.classList.remove('hidden');
      el.innerHTML = `<p class="font-bold text-green-800">Results:</p><p class="text-sm">Field Area: <strong>${area.toFixed(0)} m²</strong></p><p class="text-sm">Cut Volume: <strong>${cutVol.toFixed(1)} m³</strong></p><p class="text-sm">Fill Volume: <strong>${fillVol.toFixed(1)} m³</strong></p><p class="text-sm">Elevation Diff: <strong>${(high-low).toFixed(2)} m</strong></p>`;
    }

    function calcPump() {
      const Q = parseFloat(document.getElementById('p-discharge').value);
      const staticH = parseFloat(document.getElementById('p-static').value);
      const friction = parseFloat(document.getElementById('p-friction').value);
      const delivery = parseFloat(document.getElementById('p-delivery').value);
      const pEff = parseFloat(document.getElementById('p-peff').value) / 100;
      const mEff = parseFloat(document.getElementById('p-meff').value) / 100;
      if (!Q || !pEff || !mEff) return;

      const tdh = staticH + friction + delivery;
      const whp = (Q * tdh * 9.81) / 1000;
      const bhp = whp / pEff;
      const motorKW = bhp / mEff;
      const motorHP = motorKW * 1.341;
      const pumpHP = (Q * tdh) / (75 * pEff);

      const standardSizes = [0.5, 0.75, 1, 1.5, 2, 3, 5, 7.5, 10, 15, 20, 25, 30, 40, 50];
      const recommendedPump = standardSizes.find(s => s >= pumpHP) || 50;
      const standardMotorSizes = [0.5, 0.75, 1, 1.5, 2, 3, 5, 7.5, 10, 15, 20, 25, 30, 40, 50, 60, 75];
      const recommendedMotor = standardMotorSizes.find(s => s >= motorHP) || 75;

      const el = document.getElementById('pump-result');
      el.classList.remove('hidden');
      el.innerHTML = `
        <div class="space-y-3">
          <p class="font-bold text-green-800">Head:</p>
          <p class="text-sm">TDH: <strong>${tdh.toFixed(1)} m</strong> (Static ${staticH} + Friction ${friction} + Delivery ${delivery})</p>
          <p class="font-bold text-green-800">Power:</p>
          <p class="text-sm">Water Power: <strong>${whp.toFixed(2)} kW</strong> | Brake: <strong>${bhp.toFixed(2)} kW</strong></p>
          <p class="text-sm">Pump HP: <strong>${pumpHP.toFixed(2)} HP</strong> | Motor: <strong>${motorKW.toFixed(2)} kW (${motorHP.toFixed(1)} HP)</strong></p>
          <p class="font-bold text-green-800">Recommended:</p>
          <p class="text-sm">Pump: <strong>${recommendedPump} HP</strong> | Motor: <strong>${recommendedMotor} HP</strong></p>
        </div>`;
    }

    function calcSolar() {
      const water = parseFloat(document.getElementById('s-water').value);
      const tdh = parseFloat(document.getElementById('s-tdh').value);
      const psh = parseFloat(document.getElementById('s-psh').value);
      const eff = parseFloat(document.getElementById('s-peff').value) / 100;
      const panelW = parseFloat(document.getElementById('s-panel').value);
      if (!water || !tdh || !psh || !eff || !panelW) return;

      const hydraulicKWh = (water * 1000 * 9.81 * tdh) / 3600000;
      const requiredKWh = hydraulicKWh / eff;
      const arrayKW = requiredKWh / psh;
      const numPanels = Math.ceil((arrayKW * 1000) / panelW);
      const annualKWh = requiredKWh * 365;
      const annualSavings = annualKWh * 0.5 * 290;
      const totalSystemCost = arrayKW * 180000;
      const paybackYears = totalSystemCost / annualSavings;

      const el = document.getElementById('solar-result');
      el.classList.remove('hidden');
      el.innerHTML = `
        <div class="space-y-3">
          <p class="font-bold text-green-800">System Design:</p>
          <p class="text-sm">Hydraulic Energy: <strong>${hydraulicKWh.toFixed(2)} kWh/day</strong> | Required: <strong>${requiredKWh.toFixed(2)} kWh/day</strong></p>
          <p class="text-sm">Array: <strong>${arrayKW.toFixed(2)} kWp</strong> | Panels (${panelW}W): <strong>${numPanels}</strong></p>
          <p class="font-bold text-green-800">Financial:</p>
          <p class="text-sm">Est. Cost: <strong>PKR ${totalSystemCost.toLocaleString()}</strong> | Annual Savings: <strong>PKR ${annualSavings.toLocaleString('en-PK',{maximumFractionDigits:0})}</strong></p>
          <p class="text-sm">Payback: <strong>${paybackYears.toFixed(1)} years</strong></p>
        </div>`;
    }

    function calcDrip() {
      const area = parseFloat(document.getElementById('d-area').value);
      const rowSpacing = parseFloat(document.getElementById('d-spacing-row').value);
      const emitterSpacing = parseFloat(document.getElementById('d-spacing-emitter').value);
      const emitterRate = parseFloat(document.getElementById('d-emitter-rate').value);
      const dailyNeed = parseFloat(document.getElementById('d-daily').value);
      if (!area || !rowSpacing || !emitterSpacing || !emitterRate || !dailyNeed) return;
      const areaM2 = area * 4046.86;
      const totalEmitters = Math.ceil(areaM2 / (rowSpacing * emitterSpacing));
      const systemFlow = (totalEmitters * emitterRate) / 1000;
      const dailyVolume = (dailyNeed / 1000) * areaM2;
      const runTime = dailyVolume / systemFlow;
      const el = document.getElementById('drip-result');
      el.classList.remove('hidden');
      el.innerHTML = `<p class="font-bold text-green-800">Results:</p><p class="text-sm">Total Emitters: <strong>${totalEmitters.toLocaleString()}</strong></p><p class="text-sm">System Flow: <strong>${systemFlow.toFixed(1)} m³/hr</strong></p><p class="text-sm">Daily Volume: <strong>${dailyVolume.toFixed(1)} m³</strong></p><p class="text-sm">Run Time: <strong>${runTime.toFixed(1)} hrs/day</strong></p>`;
    }

    function designDripSystem() {
      const crop = document.getElementById('dd-crop').value;
      const plantSpacing = parseFloat(document.getElementById('dd-plant-spacing').value);
      const rowSpacing = parseFloat(document.getElementById('dd-row-spacing').value);
      const emitterFlow = parseFloat(document.getElementById('dd-emitter-flow').value);
      const fieldLength = parseFloat(document.getElementById('dd-field-length').value);
      const fieldWidth = parseFloat(document.getElementById('dd-field-width').value);
      const lateralDia = parseFloat(document.getElementById('dd-lateral-diameter').value);
      const submainDia = parseFloat(document.getElementById('dd-submain-diameter').value);
      const mainlineDia = parseFloat(document.getElementById('dd-mainline-diameter').value);
      const operatingHours = parseFloat(document.getElementById('dd-operating-hours').value);
      if (!crop || !plantSpacing || !rowSpacing || !emitterFlow || !fieldLength || !fieldWidth || !operatingHours) return;

      const fieldArea = fieldLength * fieldWidth;
      const numRows = Math.ceil(fieldWidth / rowSpacing);
      const emittersPerRow = Math.ceil(fieldLength / plantSpacing);
      const totalEmitters = numRows * emittersPerRow;
      const lateralFlowLhr = emittersPerRow * emitterFlow;
      const mainlineFlowLhr = numRows * lateralFlowLhr;
      const mainlineFlowLs = mainlineFlowLhr / 3600;
      const totalDailyVolume = (totalEmitters * emitterFlow * operatingHours) / 1000;
      const dailyDepth = (totalDailyVolume / fieldArea) * 1000;

      const lateralArea = Math.PI * Math.pow(lateralDia / 2000, 2);
      const lateralVelocity = (lateralFlowLhr / 3600 / 1000) / lateralArea;
      const mainlineArea = Math.PI * Math.pow(mainlineDia / 2000, 2);
      const mainlineVelocity = (mainlineFlowLhr / 3600 / 1000) / mainlineArea;

      const el = document.getElementById('drip-design-result');
      el.classList.remove('hidden');
      el.innerHTML = `
        <div class="space-y-3">
          <p class="font-bold text-blue-900">Drip Design: ${crop}</p>
          <p class="text-sm">Field: <strong>${fieldLength}×${fieldWidth} m</strong> (${(fieldArea/4046.86).toFixed(2)} acres)</p>
          <p class="text-sm">Rows: <strong>${numRows}</strong> | Emitters/Row: <strong>${emittersPerRow}</strong> | Total: <strong>${totalEmitters.toLocaleString()}</strong></p>
          <p class="text-sm">Lateral Flow: <strong>${lateralFlowLhr.toFixed(0)} L/hr</strong> | System Flow: <strong>${mainlineFlowLhr.toFixed(0)} L/hr</strong> (${mainlineFlowLs.toFixed(2)} L/s)</p>
          <p class="text-sm">Lateral Velocity: <strong>${lateralVelocity.toFixed(2)} m/s</strong> ${lateralVelocity > 2 ? '⚠️' : '✓'} | Mainline: <strong>${mainlineVelocity.toFixed(2)} m/s</strong> ${mainlineVelocity > 2.5 ? '⚠️' : '✓'}</p>
          <p class="text-sm">Daily Volume: <strong>${totalDailyVolume.toFixed(1)} m³</strong> | Depth: <strong>${dailyDepth.toFixed(1)} mm</strong></p>
          <p class="text-sm">Material: Lateral ${(numRows*fieldLength).toFixed(0)}m (${lateralDia}mm) | Mainline ${fieldLength}m (${mainlineDia}mm)</p>
        </div>`;
    }

    function designSprinklerSystem() {
      const area = parseFloat(document.getElementById('sp-design-area').value);
      const dailyNeed = parseFloat(document.getElementById('sp-design-daily-need').value);
      const operatingHrs = parseFloat(document.getElementById('sp-design-operating-hrs').value);
      const sprinklerType = document.getElementById('sp-design-sprinkler-type').value;
      const spacing = parseFloat(document.getElementById('sp-design-spacing').value);
      const pressure = parseFloat(document.getElementById('sp-design-pressure').value);
      const throwRadius = parseFloat(document.getElementById('sp-design-throw-radius').value);
      const cuTarget = parseFloat(document.getElementById('sp-design-cu-target').value);
      if (!area || !dailyNeed || !operatingHrs || !spacing || !pressure || !throwRadius) return;

      const areaM2 = area * 4046.86;
      const totalDailyVolume = (dailyNeed / 1000) * areaM2;
      const systemFlowLhr = (totalDailyVolume / operatingHrs) * 1000;
      const systemFlowLs = systemFlowLhr / 3600;
      const numSprinklers = Math.ceil(areaM2 / (spacing * spacing));
      const sprinklerFlowLhr = systemFlowLhr / numSprinklers;
      const applicationRate = (sprinklerFlowLhr / (spacing * spacing));

      let cu = 85;
      if (spacing / throwRadius > 0.5) cu = 75;
      if (spacing / throwRadius < 0.3) cu = 88;

      const el = document.getElementById('sprinkler-design-result');
      el.classList.remove('hidden');
      el.innerHTML = `
        <div class="space-y-3">
          <p class="font-bold text-orange-900">Sprinkler Design Report</p>
          <p class="text-sm">Area: <strong>${area} acres</strong> | Daily Need: <strong>${totalDailyVolume.toFixed(1)} m³</strong></p>
          <p class="text-sm">Sprinklers: <strong>${numSprinklers}</strong> (${sprinklerType}) @ <strong>${spacing}m spacing</strong></p>
          <p class="text-sm">System Flow: <strong>${systemFlowLhr.toFixed(0)} L/hr</strong> (${systemFlowLs.toFixed(2)} L/s)</p>
          <p class="text-sm">Per Sprinkler: <strong>${sprinklerFlowLhr.toFixed(0)} L/hr</strong> | App Rate: <strong>${applicationRate.toFixed(2)} mm/hr</strong></p>
          <p class="text-sm">CU: <strong>${cu}%</strong> ${cu >= cuTarget ? '✓ Meets target' : '⚠️ Below target'} | Pressure: <strong>${pressure} bar</strong></p>
        </div>`;
    }

    function recommendPipeDiameter() {
      const Q = parseFloat(document.getElementById('pp-rec-flow').value) / 1000;
      const V_design = parseFloat(document.getElementById('pp-rec-velocity').value);
      if (!Q || !V_design) return;
      const A_required = Q / V_design;
      const D_mm = Math.sqrt((4 * A_required) / Math.PI) * 1000;
      const standardSizes = [10, 15, 20, 25, 32, 40, 50, 63, 75, 90, 100, 125, 150, 200, 250, 300, 350, 400, 450, 500, 600];
      const recommendedSize = standardSizes.find(s => s >= D_mm) || 600;
      const A_actual = Math.PI * Math.pow(recommendedSize / 2000, 2);
      const V_actual = Q / A_actual;
      const el = document.getElementById('pipe-rec-result');
      el.classList.remove('hidden');
      el.innerHTML = `<p class="font-bold text-purple-800">Recommended: <strong>${recommendedSize} mm</strong></p><p class="text-sm">Required: ${D_mm.toFixed(1)} mm | Actual Velocity: ${V_actual.toFixed(2)} m/s ${V_actual > 2.5 ? '⚠️' : '✓'}</p>`;
    }

    function calcHazenWilliams() {
      const Q = parseFloat(document.getElementById('pp-hw-flow').value) / 1000;
      const D = parseFloat(document.getElementById('pp-hw-dia').value) / 1000;
      const L = parseFloat(document.getElementById('pp-hw-length').value);
      const C = parseFloat(document.getElementById('pp-hw-c').value);
      if (!Q || !D || !L || !C) return;
      const A = Math.PI * Math.pow(D / 2, 2);
      const V = Q / A;
      const hf = (10.67 * L * Math.pow(Q, 1.852)) / (Math.pow(C, 1.852) * Math.pow(D, 4.87));
      const el = document.getElementById('pipe-hw-result');
      el.classList.remove('hidden');
      el.innerHTML = `<p class="font-bold text-blue-800">Results:</p><p class="text-sm">Velocity: <strong>${V.toFixed(2)} m/s</strong> ${V > 2.5 ? '⚠️ High' : V < 0.5 ? '⚠️ Low' : '✓'}</p><p class="text-sm">Head Loss: <strong>${hf.toFixed(2)} m</strong> | Per 100m: <strong>${((hf/L)*100).toFixed(2)} m</strong></p>`;
    }

    function calcDarcyWeisbach() {
      const Q = parseFloat(document.getElementById('pp-dw-flow').value) / 1000;
      const D = parseFloat(document.getElementById('pp-dw-dia').value) / 1000;
      const L = parseFloat(document.getElementById('pp-dw-length').value);
      const ks = parseFloat(document.getElementById('pp-dw-roughness').value) / 1000;
      if (!Q || !D || !L) return;
      const A = Math.PI * Math.pow(D / 2, 2);
      const V = Q / A;
      const nu = 1e-6;
      const Re = (V * D) / nu;
      const f = 0.25 / Math.pow(Math.log10((ks / D) / 3.7 + 5.74 / Math.pow(Re, 0.9)), 2);
      const hf = f * (L / D) * (Math.pow(V, 2) / (2 * 9.81));
      const el = document.getElementById('pipe-dw-result');
      el.classList.remove('hidden');
      el.innerHTML = `<p class="font-bold text-cyan-800">Results:</p><p class="text-sm">Velocity: <strong>${V.toFixed(2)} m/s</strong> | Re: <strong>${Re.toLocaleString()}</strong> (${Re < 2300 ? 'Laminar' : 'Turbulent'})</p><p class="text-sm">f: <strong>${f.toFixed(4)}</strong> | Head Loss: <strong>${hf.toFixed(2)} m</strong></p>`;
    }

    // Soil Analysis
    let soilTextureCache = null;
    let bulkDensityCache = null;
    let salinityCache = null;

    function calcSoil() {
      const sand = parseFloat(document.getElementById('so-sand').value);
      const silt = parseFloat(document.getElementById('so-silt').value);
      const clay = parseFloat(document.getElementById('so-clay').value);
      const om = parseFloat(document.getElementById('so-om').value);
      if (Math.abs(sand + silt + clay - 100) > 1) {
        const el = document.getElementById('soil-result');
        el.classList.remove('hidden');
        el.innerHTML = `<p class="text-red-700 font-bold">Sand + Silt + Clay must equal 100%</p>`;
        return;
      }
      let texture = 'Loam';
      if (clay >= 40) texture = 'Clay';
      else if (sand >= 85) texture = 'Sand';
      else if (silt >= 80) texture = 'Silt';
      else if (clay >= 27 && sand >= 20 && sand <= 45) texture = 'Clay Loam';
      else if (sand >= 52 && clay < 20) texture = 'Sandy Loam';
      else if (silt >= 50 && clay >= 12 && clay < 27) texture = 'Silty Clay Loam';
      else if (silt >= 50) texture = 'Silt Loam';

      const awc = texture === 'Sand' ? 0.06 : texture === 'Clay' ? 0.14 : 0.17;
      soilTextureCache = { texture, sand, silt, clay, om, awc };

      const el = document.getElementById('soil-result');
      el.classList.remove('hidden');
      el.innerHTML = `<p class="font-bold text-green-800">Results:</p><p class="text-sm">Texture: <strong>${texture}</strong></p><p class="text-sm">AWC: <strong>${(awc*100).toFixed(0)}%</strong></p><p class="text-sm">OM: <strong>${om}%</strong> ${om < 1.5 ? '⚠️ Low' : om > 3 ? '✓ Good' : '— Moderate'}</p>`;
      generateSoilHealthReport();
    }

    function calcBulkDensity() {
      const dryWeight = parseFloat(document.getElementById('so-dry-weight').value);
      const coreVolume = parseFloat(document.getElementById('so-core-volume').value);
      const particleDensity = parseFloat(document.getElementById('so-particle-density').value);
      const infiltrationObs = parseFloat(document.getElementById('so-infiltration-obs').value);
      if (!dryWeight || !coreVolume || !particleDensity || isNaN(infiltrationObs)) return;

      const bd = dryWeight / coreVolume;
      const porosity = (1 - bd / particleDensity) * 100;
      const airPorosity = porosity * 0.5;

      let infStatus = '';
      if (infiltrationObs > 25) infStatus = '✓ Rapid';
      else if (infiltrationObs > 12) infStatus = '✓ Moderate';
      else if (infiltrationObs > 6) infStatus = '⚠️ Moderately slow';
      else infStatus = '⚠️ Slow';

      let permClass = '';
      if (infiltrationObs > 50) permClass = 'Very rapid';
      else if (infiltrationObs > 20) permClass = 'Rapid';
      else if (infiltrationObs > 6.3) permClass = 'Moderate to rapid';
      else if (infiltrationObs > 2) permClass = 'Moderate';
      else if (infiltrationObs > 0.5) permClass = 'Slow';
      else permClass = 'Very slow';

      bulkDensityCache = { bd, porosity, airPorosity, waterPorosity: porosity * 0.5, infiltrationObs, infStatus, permClass };

      const el = document.getElementById('bd-result');
      el.classList.remove('hidden');
      el.innerHTML = `<p class="font-bold text-blue-900">Results:</p><p class="text-sm">BD: <strong>${bd.toFixed(2)} g/cm³</strong> ${bd < 1.2 ? '✓ Optimal' : bd < 1.5 ? '⚠️ Moderate' : '⚠️ Compacted'}</p><p class="text-sm">Porosity: <strong>${porosity.toFixed(1)}%</strong></p><p class="text-sm">Infiltration: <strong>${infiltrationObs.toFixed(1)} mm/hr</strong> — ${infStatus} (${permClass})</p>`;
      generateSoilHealthReport();
    }

    function calcSalinity() {
      const ec = parseFloat(document.getElementById('so-ec').value);
      const ph = parseFloat(document.getElementById('so-ph').value);
      const cec = parseFloat(document.getElementById('so-cec').value);
      const esp = parseFloat(document.getElementById('so-ese').value);
      if (!ec || !ph || !cec) return;

      let ecStatus = ec < 2 ? '✓ Non-saline' : ec < 4 ? '⚠️ Slightly saline' : ec < 8 ? '⚠️ Moderately saline' : '🚨 Highly saline';
      let phStatus = ph < 6 ? '⚠️ Acidic' : ph <= 7.5 ? '✓ Neutral' : ph < 8.5 ? '⚠️ Slightly alkaline' : '🚨 Alkaline';
      let phClass = ph < 6 ? 'Acidic' : ph <= 7.5 ? 'Optimal' : ph < 8.5 ? 'Slightly alkaline' : 'Very alkaline';
      let cecStatus = cec < 5 ? '⚠️ Very low' : cec < 15 ? '⚠️ Low to moderate' : cec < 25 ? '✓ Good' : '✓ High';
      let sodicity = esp < 6 ? '✓ Non-sodic' : esp < 15 ? '⚠️ Sodic' : '🚨 Highly sodic';
      let salinity = ec < 2 ? 'Not affected' : ec < 4 ? 'May affect sensitive crops' : 'Affects most crops';

      salinityCache = { ec, ph, cec, esp, ecStatus, phStatus, phClass, cecStatus, sodicity, salinity };

      const el = document.getElementById('salinity-result');
      el.classList.remove('hidden');
      el.innerHTML = `<p class="font-bold text-amber-900">Results:</p><p class="text-sm">EC: <strong>${ec} dS/m</strong> — ${ecStatus}</p><p class="text-sm">pH: <strong>${ph}</strong> — ${phStatus}</p><p class="text-sm">CEC: <strong>${cec} cmol/kg</strong> — ${cecStatus}</p><p class="text-sm">ESP: <strong>${esp}%</strong> — ${sodicity}</p>`;
      generateSoilHealthReport();
    }

    function generateSoilHealthReport() {
      if (!soilTextureCache || !bulkDensityCache || !salinityCache) return;
      const t = soilTextureCache, bd = bulkDensityCache, s = salinityCache;

      let healthScore = 100;
      if (bd.bd > 1.5) healthScore -= 10;
      if (bd.infiltrationObs < 6.3) healthScore -= 15;
      if (s.ec > 4) healthScore -= 20;
      if (s.ph < 6 || s.ph > 8.5) healthScore -= 10;
      if (s.esp > 15) healthScore -= 15;
      if (s.cec < 5) healthScore -= 5;
      if (t.om < 1.5) healthScore -= 10;
      healthScore = Math.max(0, healthScore);

      let healthDesc = healthScore >= 85 ? '🌿 Excellent' : healthScore >= 70 ? '🌱 Good' : healthScore >= 55 ? '⚠️ Fair' : '🚨 Poor';

      const recommendations = [];
      if (t.om < 2) recommendations.push('Increase organic matter through compost');
      if (bd.bd > 1.5) recommendations.push('Consider deep ripping for compaction');
      if (bd.infiltrationObs < 6.3) recommendations.push('Improve drainage');
      if (s.ec > 4) recommendations.push('Apply fresh water leaching');
      if (s.ph < 6) recommendations.push('Apply lime to raise pH');
      if (s.ph > 8.5) recommendations.push('Consider sulfur application');
      if (s.esp > 15) recommendations.push('Use gypsum + leaching for sodicity');

      document.getElementById('rpt-texture').textContent = t.texture;
      document.getElementById('rpt-composition').textContent = `Sand ${t.sand}%, Silt ${t.silt}%, Clay ${t.clay}%`;
      document.getElementById('rpt-awc').textContent = `${(t.awc * 100).toFixed(0)}%`;
