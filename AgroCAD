    function renderFiltered() { renderProfiles(getFilteredData()); }

    function updateDashboard() {
      document.getElementById('dash-total').textContent = allData.length;
      document.getElementById('dash-area').textContent = allData.reduce((s, i) => s + (parseFloat(i.area_acres) || 0), 0).toFixed(0);
      document.getElementById('dash-drip').textContent = allData.filter(i => i.irrigation_method === 'Drip').length;
      document.getElementById('dash-sprinkler').textContent = allData.filter(i => i.irrigation_method === 'Sprinkler').length;
    }

    function renderProfiles(data) {
      const list = document.getElementById('profiles-list');
      const empty = document.getElementById('empty-profiles');
      if (data.length === 0) { empty.classList.remove('hidden'); list.innerHTML = ''; return; }
      empty.classList.add('hidden');
      const existing = new Map([...list.children].map(el => [el.dataset.id, el]));
      const newIds = new Set(data.map(i => i.__backendId));
      existing.forEach((el, id) => { if (!newIds.has(id)) el.remove(); });
      data.forEach(item => {
        if (existing.has(item.__backendId)) {
          const card = existing.get(item.__backendId);
          card.querySelector('.farm-info').innerHTML = buildFarmInfo(item);
        } else {
          const card = document.createElement('div');
          card.dataset.id = item.__backendId;
          card.className = 'bg-white rounded-lg p-4 shadow-sm border-l-4 border-green-600 flex justify-between items-start';
          card.innerHTML = `<div class="farm-info">${buildFarmInfo(item)}</div><button class="del-btn text-red-500 hover:text-red-700 p-1" title="Delete"><i data-lucide="trash-2" class="w-4 h-4"></i></button>`;
          card.querySelector('.del-btn').addEventListener('click', async () => {
            card.style.opacity = '0.5';
            const r = await window.dataSdk.delete(item);
            if (!r.isOk) { card.style.opacity = '1'; showStatus('Delete failed', true); }
