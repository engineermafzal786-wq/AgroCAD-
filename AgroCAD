      const totalCostPerAcre = seed + fert + pesticides + irrigation + labor + machinery + other + landRent;
      const totalCostOfProduction = totalCostPerAcre * area;
      const grossMargin = grossRevenue - totalCostOfProduction;
      const netMargin = grossMargin;
      const profitPerAcre = netMargin / area;
      const roiPercent = (netMargin / totalCostOfProduction * 100);

      // === BREAK-EVEN ANALYSIS ===
      const beYield = totalCostPerAcre / bePrice;
      const bePrice_ = totalCostPerAcre / yield_;
      const beAreaNeeded = totalCostOfProduction / (bePrice * yield_);
      const safetyMarginYield = ((yield_ - beYield) / yield_ * 100);
      const safetyMarginPrice = ((bePrice_ - bePrice) / bePrice * 100);

