    document.getElementById('filter-irrigation').addEventListener('change', renderFiltered);

    function getFilteredData() {
      const q = document.getElementById('search-input').value.toLowerCase();
      const prov = document.getElementById('filter-province').value;
      const irr = document.getElementById('filter-irrigation').value;
      return allData.filter(item => {
        if (q && !(item.farm_name || '').toLowerCase().includes(q) && !(item.client_name || '').toLowerCase().includes(q)) return false;
        if (prov && item.province !== prov) return false;
        if (irr && item.irrigation_method !== irr) return false;
        return true;
      });
