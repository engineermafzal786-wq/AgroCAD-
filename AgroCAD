    function generatePumpReport() {
      const Q = parseFloat(document.getElementById('p-discharge').value) || 10;
      const staticH = parseFloat(document.getElementById('p-static').value) || 20;
      const friction = parseFloat(document.getElementById('p-friction').value) || 3;
      const delivery = parseFloat(document.getElementById('p-delivery').value) || 2;
      const pEff = parseFloat(document.getElementById('p-peff').value) || 65;
