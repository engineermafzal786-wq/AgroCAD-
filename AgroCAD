      const btn = e.target.querySelector('[type="submit"]');
      btn.disabled = true; btn.textContent = 'Saving...';
      const record = {
        farm_name: document.getElementById('farm_name').value,
        client_name: document.getElementById('client_name').value,
        contact: document.getElementById('contact').value,
        gps_location: document.getElementById('gps_location').value,
        province: document.getElementById('province').value,
        district: document.getElementById('district').value,
        area_acres: parseFloat(document.getElementById('area_acres').value) || 0,
        soil_type: document.getElementById('soil_type').value,
        water_source: document.getElementById('water_source').value,
        irrigation_method: document.getElementById('irrigation_method').value,
        main_crop: document.getElementById('main_crop').value,
        created_at: new Date().toISOString()
      };
      const result = await window.dataSdk.create(record);
      btn.disabled = false; btn.textContent = 'Save Profile';
      if (result.isOk) { e.target.reset(); document.getElementById('farm-form').classList.add('hidden'); showStatus('Profile saved!', false); }
      else { showStatus('Error saving profile.', true); }
